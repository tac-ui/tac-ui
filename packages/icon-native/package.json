{
  "name": "@tac-ui/icon-native",
  "version": "1.0.1",
  "description": "Icon package for Tac UI React Native — lucide-react-native + TacLogo",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "lucide-react-native": "^0.577.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": ">=0.78.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.2.4",
    "react-native": "^0.83.0",
    "react-native-svg": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
