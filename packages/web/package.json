{
  "name": "@tac-ui/web",
  "version": "1.0.1",
  "description": "Web components for Tac UI (Next.js / React)",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.mjs",
      "require": "./dist/icons.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.mjs",
      "require": "./dist/tailwind/preset.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tac-ui/shared": "workspace:*",
    "@tac-ui/tokens": "workspace:*",
    "@tac-ui/icon": "workspace:*",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^12.34.0",
    "tailwind-merge": "^3.4.1"
  },
  "peerDependencies": {
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next-themes": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next-themes": "^0.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
